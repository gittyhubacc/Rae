# structs

using std

struct main:nested
	i32 a
	i32 z
	i32 b
	i32 c
end

struct main:point
	i32 x
	i32 y
	nested nested
end

export proc main:point_tst
i32 (i32 some_x, i32 some_y)
	bind point p
	p.x = some_x * 2
	p.y = some_y * 3
	p.nested.z = 33
	return p.x + p.y + p.nested.z
end

export proc main:entry_point
i32 ()
	bind point pnt
	pnt.x = 11
	pnt.y = 22
	pnt.nested.z = 33
	return point_tst(pnt.x, pnt.y) - (11*2 + 22*3) - pnt.nested.z
end
